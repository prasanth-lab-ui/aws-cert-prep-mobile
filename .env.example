# Copy this to .env and update with your backend URL
API_BASE_URL=http://10.0.2.2:5000/api
# For physical device, use your machine's local IP:
# API_BASE_URL=http://192.168.1.x:5000/api
# For production:
# API_BASE_URL=https://your-backend.com/api

# Google Sign-In Web Client ID (from Google Cloud Console -> OAuth 2.0 Client IDs -> Web).
# Used as the serverClientId so we receive an idToken the backend can verify.
GOOGLE_WEB_CLIENT_ID=
